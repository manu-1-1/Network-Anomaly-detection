   "source": [
    "df_train = pd.read_csv(\"Datasets/UNSW_NB15_training-set.csv\")\n",
    "df_test  = pd.read_csv(\"Datasets/UNSW_NB15_testing-set.csv\")\n",
    "\n",
    "print(\"Train shape:\", df_train.shape)\n",
    "print(\"Test shape :\", df_test.shape)\n",
    "\n",
    "df_train.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "dd012532-ea66-4b2d-8c9e-6c445db96d62",
   "metadata": {},
   "outputs": [],
   "source": [
    "drop_cols = ['id', 'attack_cat']\n",
    "\n",
    "df_train = df_train.drop(columns=drop_cols)\n",
    "df_test  = df_test.drop(columns=drop_cols)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "0e47ce94-e148-48bd-b4ff-59af2e43691d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "X_train: (175341, 42)\n",
      "X_test : (82332, 42)\n"
     ]
    }
   ],
   "source": [
    "X_train = df_train.drop(columns=['label'])\n",
    "y_train = df_train['label']\n",
    "\n",
    "X_test  = df_test.drop(columns=['label'])\n",
    "y_test  = df_test['label']\n",
    "\n",
    "print(\"X_train:\", X_train.shape)\n",
    "print(\"X_test :\", X_test.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "22e02caf-666a-47e6-be4c-43b7c3df0177",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.preprocessing import OneHotEncoder\n",
    "from sklearn.compose import ColumnTransformer\n",
    "\n",
    "num_features = X_train.select_dtypes(include=['int64','float64']).columns\n",
    "cat_features = X_train.select_dtypes(include=['object']).columns\n",
    "\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', 'passthrough', num_features),\n",
    "        ('cat', OneHotEncoder(\n",
    "            handle_unknown='ignore',\n",
    "            min_frequency=50\n",
    "        ), cat_features)\n",
    "    ]\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "f247f9eb-8202-4fc8-bf9f-4d31d6a72106",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "rf_model = RandomForestClassifier(\n",
    "    n_estimators=300,\n",
    "    max_depth=20,\n",
    "    min_samples_leaf=5,\n",
    "    max_features='sqrt',\n",
    "    class_weight='balanced',\n",
    "    n_jobs=-1,\n",
    "    random_state=42\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "a7cdc204-9e67-4925-9f98-46d282254a7b",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.pipeline import Pipeline\n",
    "\n",
    "pipeline = Pipeline(steps=[\n",
    "    ('preprocessing', preprocessor),\n",
    "    ('classifier', rf_model)\n",
    "])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "6774c3b5-1549-401a-be12-727edab5ca14",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training Time (s): 17.81\n"
     ]
    }
   ],
   "source": [
    "start_time = time.time()\n",
    "pipeline.fit(X_train, y_train)\n",
    "training_time = time.time() - start_time\n",
    "\n",
    "print(\"Training Time (s):\", round(training_time, 2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "6d4b53e3-0dd2-4d09-b20a-94fc14a7b6a5",
   "metadata": {},
   "outputs": [],
   "source": [
    "y_prob = pipeline.predict_proba(X_test)[:, 1]\n",
    "\n",
    "# IDS-friendly threshold\n",
    "THRESHOLD = 0.3\n",
    "y_pred = (y_prob > THRESHOLD).astype(int)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "dd0af912-1655-465e-b59f-0d22bbbb2a8e",
   "metadata": {},
   "outputs": [
